OPENAI_API_KEY=your_api_key_here
OPENAI_MAIN_MODEL=gpt-5.5
OPENAI_CHEAP_MODEL=gpt-5.4-mini
FINN_SIGNAL_RECIPIENTS=you@example.com
FINN_SIGNAL_BCC=
FINN_SIGNAL_FEEDBACK_EMAIL=you@example.com
FINN_SIGNAL_FEEDBACK_BASE_URL=https://your-project.vercel.app
FINN_SIGNAL_DAYS=7
FINN_SIGNAL_MAX_EMAILS=15
FINN_SIGNAL_MAX_ITEMS_TO_SCORE=120
FINN_SIGNAL_EXTRACT_WORKERS=4
FINN_SIGNAL_OPENAI_TIMEOUT_SECONDS=120
FINN_SIGNAL_GMAIL_RETRIES=5
FINN_SIGNAL_GMAIL_RETRY_SECONDS=30
FINN_SIGNAL_PROCESS_FEEDBACK=true
FINN_SIGNAL_FEEDBACK_DAYS=14
FINN_SIGNAL_FEEDBACK_MAX_EMAILS=20
FINN_SIGNAL_USERS_DIR=data/users

# Web console. For local use, leave these as-is.
# For Render, set PORT from Render, FINN_SIGNAL_CONSOLE_HOST=0.0.0.0,
# and FINN_SIGNAL_PUBLIC_URL=https://your-app.onrender.com.
FINN_SIGNAL_CONSOLE_HOST=127.0.0.1
FINN_SIGNAL_PUBLIC_URL=
FINN_SIGNAL_ENABLE_HOSTED_SCHEDULER=false
FINN_SIGNAL_SCHEDULER_INTERVAL_SECONDS=300
FINN_SIGNAL_TIMEZONE=America/New_York
FINN_SIGNAL_SCHEDULER_STALE_SECONDS=1200
FINN_SIGNAL_SCHEDULER_MAX_RUN_SECONDS=3600
FINN_SIGNAL_SEND_STALE_SECONDS=900
FINN_SIGNAL_GOOGLE_CLIENT_CONFIG_JSON=

# Vercel-only variables for api/feedback.py
FINN_SIGNAL_FEEDBACK_TO=you@example.com

# Preferred Vercel feedback sender: use Gmail API forwarding.
FINN_SIGNAL_GMAIL_CLIENT_ID=your_google_oauth_client_id
FINN_SIGNAL_GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
FINN_SIGNAL_GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token

# Optional Vercel fallback: use Resend instead of Gmail API forwarding.
RESEND_API_KEY=your_resend_api_key
FINN_SIGNAL_FEEDBACK_FROM=Finn-Signal <feedback@your-domain.com>
